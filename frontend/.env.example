# URL of the Flask API backend (used in production builds on GitHub Pages)
# For local dev, the Vite proxy (vite.config.js) handles /api automatically.
# For production, set this to your deployed backend URL (e.g. PythonAnywhere / Render).
# Set as a GitHub Actions variable (VITE_API_URL) in repo settings → Actions → Variables.
VITE_API_URL=https://your-backend-url.com
